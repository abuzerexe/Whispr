/// Copy this file to `secrets.dart` and set your OpenAI API key.
/// `secrets.dart` is gitignored and must not be committed.
abstract final class Secrets {
  Secrets._();

  static const String openAiApiKey = String.fromEnvironment(
    'OPEN_AI_API_KEY',
    defaultValue: 'YOUR_OPENAI_API_KEY_HERE',
  );
}
